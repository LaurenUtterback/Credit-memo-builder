<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Loan Documents — South River Capital — {{ borrower_name }}</title>
<style>
:root{--navy:#0f2a43;--navy-2:#1c3d5a;--gold:#b9952b;--ink:#1a1a1a;--ink-soft:#444;--rule:#cdd3da;--rule-strong:#9aa6b2;--paper:#fff;--desk:#e9e7e0;--zebra:#f4f6f8;}
*{box-sizing:border-box;}html,body{margin:0;padding:0;}
body{background:var(--desk);font-family:"Times New Roman",Times,serif;font-size:10pt;line-height:1.42;color:var(--ink);-webkit-font-smoothing:antialiased;padding:32px 16px 64px;}
.page{width:8.5in;background:var(--paper);margin:0 auto 28px;padding:.7in .75in .85in;box-shadow:0 2px 14px rgba(0,0,0,.12);border-radius:2px;position:relative;}
.docpage{min-height:11in;}
p{margin:0 0 7pt;text-wrap:pretty;}strong,b{font-weight:bold;}
h2.sec{font-size:11.5pt;font-weight:bold;color:#000;text-transform:uppercase;letter-spacing:.04em;margin:0 0 8pt;padding-bottom:4pt;border-bottom:1.5pt solid var(--navy);display:flex;align-items:baseline;gap:8pt;}
h3.sub{font-size:10pt;font-weight:bold;color:#000;margin:14pt 0 6pt;text-transform:uppercase;letter-spacing:.03em;}
.masthead{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:3px solid var(--navy);padding-bottom:10pt;margin-bottom:4pt;}
.brand{display:flex;align-items:center;gap:11px;}.brand .brand-logo{height:50px;width:auto;display:block;background:#fff;padding:5px 8px;border-radius:4px;}
.doc-meta{text-align:right;font-family:Arial,Helvetica,sans-serif;}
.doc-meta .conf{font-size:7pt;font-weight:bold;letter-spacing:.18em;color:#fff;background:var(--gold);padding:2pt 6pt;display:inline-block;text-transform:uppercase;}
.doc-meta .dt{font-size:8pt;color:var(--ink-soft);margin-top:6pt;}.doc-meta .dt span{color:var(--ink);font-weight:bold;}
.doc-title{text-align:center;margin:14pt 0 16pt;}.doc-title .kicker,.doc-head .kicker{font-family:Arial,Helvetica,sans-serif;font-size:7.5pt;letter-spacing:.4em;color:var(--gold);text-transform:uppercase;font-weight:bold;}
.doc-title h1{font-size:21pt;font-weight:bold;color:#000;letter-spacing:.04em;margin:5pt 0 0;text-transform:uppercase;}
.doc-head{text-align:center;margin:0 0 14pt;padding-bottom:8pt;border-bottom:1.5pt solid var(--navy);}
.doc-head h1{font-size:15pt;font-weight:bold;color:#000;letter-spacing:.05em;margin:4pt 0 0;text-transform:uppercase;}
table{width:100%;border-collapse:collapse;margin:4pt 0 6pt;font-size:9.5pt;}
th,td{border:.75pt solid var(--rule);padding:3.5pt 7pt;vertical-align:top;text-align:left;}
thead th{background:var(--navy);color:#fff;font-family:Arial,Helvetica,sans-serif;font-size:7.5pt;font-weight:bold;letter-spacing:.05em;text-transform:uppercase;border-color:var(--navy-2);}
table.kv td.k{width:30%;background:#f1f4f7;font-weight:bold;color:#000;white-space:nowrap;}
table.kv.two td.k{width:18%;}
.num-col{text-align:right;font-variant-numeric:tabular-nums;white-space:nowrap;}
tbody tr.total td{font-weight:bold;background:#eef1f4;border-top:1.25pt solid var(--rule-strong);}
tbody tr.grand td{font-weight:bold;background:var(--navy);color:#fff;border-color:var(--navy-2);}
.zebra tbody tr:nth-child(even) td{background:var(--zebra);}
/* legal clause layout */
p.cl{margin:0 0 7pt;}
p.just{text-align:justify;}
p.ctr{text-align:center;}
p.fli{text-indent:.35in;}
p.lv1{padding-left:.4in;text-indent:-.4in;}
p.lv2{padding-left:.8in;text-indent:-.4in;}
p.lv1 .mk,p.lv2 .mk{display:inline-block;width:.4in;text-indent:0;}
p.sec-head{font-weight:bold;margin:12pt 0 7pt;}
p.sec-head .mk{display:inline-block;width:.3in;}
.exhibit{margin-top:22pt;border-top:1.5pt solid var(--navy);padding-top:10pt;break-before:page;page-break-before:always;}
.ex-title{font-family:Arial,Helvetica,sans-serif;font-size:8pt;letter-spacing:.25em;color:var(--gold);text-transform:uppercase;font-weight:bold;text-align:center;margin:0 0 4pt;}
/* signature blocks */
.sig-grid{display:grid;grid-template-columns:1fr 1fr;gap:24pt;margin:20pt 0 8pt;break-inside:avoid;}
.sig-cap{font-weight:bold;margin:0 0 26pt;}
.sig-line{border-bottom:1pt solid #000;height:26pt;position:relative;}
.sig-line.sig-seal::after{content:"";}
.sig-seal{display:flex;align-items:flex-end;justify-content:flex-end;font-size:9pt;color:var(--ink-soft);padding-bottom:1pt;}
.sig-name{font-weight:bold;margin:3pt 0 7pt;}
.notice-tbl{width:70%;}
/* UCC form */
table.ucc{font-family:Arial,Helvetica,sans-serif;font-size:9pt;}
table.ucc td{border:.75pt solid var(--rule-strong);padding:2.5pt 5pt;}
.ucc-lab{font-size:6.3pt;letter-spacing:.04em;color:var(--ink-soft);text-transform:uppercase;font-weight:bold;display:block;margin-bottom:1pt;}
.ucc-title{background:#f1f4f7;}
.ucc-sec{background:var(--navy);}
.ucc-sec .ucc-lab{color:#fff;margin:0;}
.ucc-foot{font-size:6.5pt;text-align:center;color:var(--ink-soft);}
.note-fine{font-size:8.5pt;color:var(--ink-soft);}
.pg-footer{position:absolute;left:.75in;right:.75in;bottom:.42in;display:flex;justify-content:space-between;align-items:center;font-family:Arial,Helvetica,sans-serif;font-size:6.8pt;letter-spacing:.1em;color:#8a8a8a;text-transform:uppercase;border-top:.75pt solid var(--rule);padding-top:5pt;}
@page{size:letter;margin:.7in .75in .6in;}
@media print{body{background:none;padding:0;}.page{width:auto;min-height:0;margin:0;padding:0;box-shadow:none;border-radius:0;}.docpage{break-before:page;}.docpage:first-of-type{break-before:auto;}.pg-footer{display:none;}.sig-grid,tr,thead{break-inside:avoid;}h2.sec,h3.sub{break-after:avoid;}th,td,thead th,tbody tr.grand td,.brand .brand-logo,.doc-meta .conf,.ucc-sec{-webkit-print-color-adjust:exact;print-color-adjust:exact;}}
</style></head>
<body style="background-color:rgba(255,255,253,0.98)">

<div class="page docpage">
<header class="masthead"><div class="brand"><img class="brand-logo" src="{{ logo }}" alt="South River Capital"></div><div class="doc-meta"><div class="dt">Closing Date: <span>{{ closing_date }}</span></div>{% if loan_number %}<div class="dt">Loan No.: <span>{{ loan_number }}</span></div>{% endif %}</div></header>
<div class="doc-title"><div class="kicker">South River Capital</div><h1>Loan Documents</h1></div>
<table class="kv two"><tbody>
<tr><td class="k">Borrower</td><td>{{ borrower_name }}</td><td class="k">Team / Employer</td><td>{% if no_team_contract %}None{% else %}{{ team_name }}{% endif %}</td></tr>
<tr><td class="k">Address</td><td>{{ borrower_street }}, {{ borrower_city_state_zip }}</td><td class="k">Contract</td><td>{% if no_team_contract %}None{% else %}{{ contract_title }} dated {{ contract_date_long }}{% endif %}</td></tr>
<tr><td class="k">Loan Amount</td><td>{{ loan_amount }}</td><td class="k">Interest Rate</td><td>{{ interest_rate }}%</td></tr>
<tr><td class="k">Closing Date</td><td>{{ closing_date }}</td><td class="k">Maturity Date</td><td>{{ maturity_date_long }}</td></tr>
</tbody></table>
<section style="margin-top:16pt"><h2 class="sec">Documents in this Package</h2>
<table class="kv"><tbody>
{% for d in doc_index %}<tr><td class="k" style="width:40px;text-align:center">{{ loop.index }}</td><td>{{ d }}</td></tr>
{% endfor %}</tbody></table>
<p class="note-fine" style="margin-top:14pt">Prepared by South River Capital, LLC. These documents follow South River&rsquo;s standard athlete-loan closing set; confirm all terms against the executed versions.</p></section>
</div>
{% if include.affidavit %}
<div class="page docpage">
<div class="doc-head"><div class="kicker">South River Capital</div><h1>Business Entity Affidavit</h1></div>
