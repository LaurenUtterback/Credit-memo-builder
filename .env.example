# Copy this file to .env and fill in your values. NEVER commit .env.
# Extraction uses your Claude SUBSCRIPTION USAGE, not a pay-per-token API key.
# Generate this token by running:  claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=paste-your-token-here

# Optional: override the extraction model
# EXTRACTION_MODEL=claude-sonnet-4-6

# Optional: comma-separated allowed CORS origins (frontend URLs)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Loan Documents builder - receiving account printed on the Payment Direction
# Letter. Fill in your own values; never commit the real .env.
SRC_ACCOUNT_NAME=
SRC_BANK_NAME=
SRC_BANK_ACCOUNT_NO=
SRC_BANK_ABA=
SRC_BANK_ADDRESS_1=
SRC_BANK_ADDRESS_2=
SRC_BANK_CONTACT=
SRC_BANK_PHONE=

# Participation Agreement - "Send out for signature" step. The SRC signer
# identity and your e-signature site live ONLY here (the repo is public).
SRC_SIGNER_NAME=
SRC_SIGNER_EMAIL=
ESIGN_NAME=
ESIGN_URL=

# Participation Agreement - one-click "Send for signature" via DocuSign.
# Create a (free) developer account at https://developers.docusign.com, then in
# Apps & Keys: add an app -> copy its Integration Key, generate an RSA keypair
# (save the PRIVATE key to <project root>/docusign_private_key.txt - it is
# git-ignored), and copy your User ID and API Account ID from the same page.
# DOCUSIGN_ENV is "demo" until the integration key is promoted to production.
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_ENV=demo
# Optional overrides:
# DOCUSIGN_PRIVATE_KEY_FILE=C:\path\to\docusign_private_key.txt
# DOCUSIGN_REDIRECT_URI=https://developers.docusign.com/platform/auth/consent
