# Copy this file to .env and fill in your values. NEVER commit .env.
# Extraction uses your Claude SUBSCRIPTION USAGE, not a pay-per-token API key.
# Generate this token by running:  claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=paste-your-token-here

# Optional: override the extraction model
# EXTRACTION_MODEL=claude-sonnet-4-6

# Optional: comma-separated allowed CORS origins (frontend URLs)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
