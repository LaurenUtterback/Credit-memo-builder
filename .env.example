# Copy this file to .env and fill in your values. NEVER commit .env.
# Extraction uses your Claude SUBSCRIPTION USAGE, not a pay-per-token API key.
# Generate this token by running:  claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=paste-your-token-here

# Optional: override the extraction model
# EXTRACTION_MODEL=claude-sonnet-4-6

# Optional: comma-separated allowed CORS origins (frontend URLs)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Loan Documents builder - receiving account printed on the Payment Direction
# Letter. Fill in your own values; never commit the real .env.
SRC_ACCOUNT_NAME=
SRC_BANK_NAME=
SRC_BANK_ACCOUNT_NO=
SRC_BANK_ABA=
SRC_BANK_ADDRESS_1=
SRC_BANK_ADDRESS_2=
SRC_BANK_CONTACT=
SRC_BANK_PHONE=

# Participation Agreement - "Send out for signature" step. The SRC signer
# identity and your e-signature site live ONLY here (the repo is public).
SRC_SIGNER_NAME=
SRC_SIGNER_EMAIL=
ESIGN_NAME=
ESIGN_URL=
